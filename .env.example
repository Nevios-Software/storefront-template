# Local dev secrets live in `.dev.vars` (Cloudflare convention, gitignored).
# Copy this file's keys there, or set them in wrangler.jsonc `vars` for deploy.

# Your shop's publishable key (pk_live_… / pk_test_…) from the Nevios dashboard.
NEVIOS_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Nevios API origin. The SDK appends /storefront/2026-01.
NEVIOS_API_URL=https://api.nevios.io

# Default market / currency context (e.g. "cz").
NEVIOS_MARKET=cz
