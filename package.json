{
  "name": "nevios-store",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Nevios headless storefront starter \u2014 React Router 7 on Cloudflare, wired to @nevios/storefront-kit.",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "deploy": "node scripts/deploy.mjs",
    "deploy:direct": "react-router build && wrangler deploy",
    "smoke": "node scripts/smoke.mjs",
    "rollback": "node scripts/rollback.mjs",
    "typecheck": "wrangler types && react-router typegen && tsc",
    "cf-typegen": "wrangler types",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "dependencies": {
    "@nevios/storefront-js": "^0.1.0",
    "@nevios/storefront-kit": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.16.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.29.1",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@react-router/dev": "7.16.0",
    "@react-router/fs-routes": "7.16.0",
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.75.0"
  },
  "packageManager": "pnpm@9.15.0"
}
